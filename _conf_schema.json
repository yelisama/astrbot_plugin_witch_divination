{
  "default_type": {
    "description": "默认占卜类型",
    "type": "string",
    "default": "omikuji",
    "hint": "用户只发送 /占卜 或关键词“占卜”时使用的类型。默认 omikuji（御神签）"
  },
  "enabled_types": {
    "description": "启用的占卜类型",
    "type": "list",
    "default": [
      "omikuji",
      "tarot",
      "crystal"
    ],
    "hint": "类型ID列表，对应数据目录 types/*.json",
    "items": {
      "type": "string"
    }
  },
  "keyword_trigger_enabled": {
    "description": "启用关键词触发",
    "type": "bool",
    "default": true,
    "hint": "开启后，用户发送“占卜/抽签/今日签/塔罗/水晶球”等关键词也会触发"
  },
  "daily_free_count": {
    "description": "每日免费占卜次数",
    "type": "int",
    "default": 1,
    "hint": "每个用户每天首次生成不同类型结果可消耗免费次数，超过后扣金币",
    "slider": {
      "min": 0,
      "max": 10,
      "step": 1
    }
  },
  "daily_normal_type_limit_enabled": {
    "description": "限制每日常规占卜种类数",
    "type": "bool",
    "default": false,
    "hint": "开启后，用户每天最多只能首次解锁指定数量的常规占卜类型；同类型重复查看不计次"
  },
  "daily_normal_type_limit": {
    "description": "每日可解锁常规占卜种类数",
    "type": "int",
    "default": 3,
    "hint": "1 表示塔罗、御神签、水晶球三选一；2 表示三选二；3 表示三种都可用",
    "slider": {
      "min": 1,
      "max": 3,
      "step": 1
    }
  },
  "extra_cost": {
    "description": "额外占卜金币价格",
    "type": "int",
    "default": 10,
    "hint": "每日免费次数用完后，首次生成新类型结果所需金币",
    "slider": {
      "min": 0,
      "max": 500,
      "step": 1
    }
  },
  "coin_link_enabled": {
    "description": "启用丛雨神社金币联动",
    "type": "bool",
    "default": true,
    "hint": "当前骨架会优先尝试联动；找不到金币接口时降级为不扣费并记录日志"
  },
  "record_cleanup_interval_days": {
    "description": "记录清理间隔（天）",
    "type": "int",
    "default": 3,
    "hint": "插件启动和触发占卜时会按间隔自动清理",
    "slider": {
      "min": 1,
      "max": 30,
      "step": 1
    }
  },
  "record_keep_days": {
    "description": "记录保留天数",
    "type": "int",
    "default": 3,
    "hint": "超过该天数的占卜记录会被清理",
    "slider": {
      "min": 1,
      "max": 30,
      "step": 1
    }
  },
  "asset_dirs": {
    "description": "素材目录配置",
    "type": "object",
    "items": {
      "tarot": {
        "description": "塔罗图库目录",
        "type": "string",
        "default": "assets/tarot"
      },
      "omikuji": {
        "description": "御神签背景目录",
        "type": "string",
        "default": "assets/omikuji"
      },
      "crystal": {
        "description": "水晶球素材目录",
        "type": "string",
        "default": "assets/crystal"
      }
    }
  },
  "omikuji_render": {
